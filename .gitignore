# project
# NOTE: 各 dir は `dir/*` で中身だけ ignore する (dir 自体を ignore すると
#       配下 placeholder の `!` 再包含が効かず、空 dir を git 追跡できないため)
ComfyUI/
1_0_prompts/*
!1_0_prompts/put PNG picture(included prompt).txt
2_0_tensors/*
!2_0_tensors/put tensors.txt
2_1_errortensors/*
!2_1_errortensors/output error tensors.txt
2_2_lowtensors/*
!2_2_lowtensors/put bad tensors here (excluded from generation).txt
2_3_hightensors/*
!2_3_hightensors/put too expensive tensors here (excluded from generation).txt
3_1_SD15_checkpoint/*
!3_1_SD15_checkpoint/output SD15 checkpoint tensors.txt
3_2_SD15_LoRA/*
!3_2_SD15_LoRA/output SD15 LoRA tensors.txt
3_3_SD15_Embedding/*
!3_3_SD15_Embedding/output SD15 Embedding tensors.txt
3_9_SD15_rough/*
!3_9_SD15_rough/output SD15 rough drafts.txt
4_1_SDXL_checkpoint/*
!4_1_SDXL_checkpoint/output SDXL checkpoint tensors.txt
4_2_SDXL_LoRA/*
!4_2_SDXL_LoRA/output SDXL LoRA tensors.txt
4_3_SDXL_ControlNet/*
!4_3_SDXL_ControlNet/output ControlNet tensors.txt
4_4_SDXL_Embedding/*
!4_4_SDXL_Embedding/output SDXL Embedding tensors.txt
5_1_generated/*
!5_1_generated/output generated PNG picture(included prompt).txt
5_2_upscaled/*
!5_2_upscaled/output upscaled PNG picture(included prompt).txt
workflow_dump/
tensors_cache.toml
